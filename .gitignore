# MikroTik secrets / sensitive overrides — never commit (matches at any depth)
secrets.rsc
**/secrets.rsc
**/*.secrets.rsc
*.secret
*.pem
*.key
# ...except test fixtures (synthetic data, safe to commit).
!**/tests/**/secrets.rsc
!**/tests/**/*.secrets.rsc

# Deploy credentials (.env.example IS committed)
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Mikrotik utils
bin/*
!bin/.gitkeep

# Local output from scripts
out/

# VSCode settings and workspace files
.vscode/

# Python — virtualenvs, build artifacts, caches
.venv/
**/__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
.coverage-data/
.coverage-html/
htmlcov/
