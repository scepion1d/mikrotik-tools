{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Schema fragment (menu_ipv6.json). Merged into src/schema.json by src/schema/build.py. Do not load directly -- cross-fragment $ref uses '#/definitions/...' against the bundled output.",
  "definitions": {
    "menu_ipv6": {
      "description": "/ipv6 -- top-level IPv6 menu. Houses addresses, DHCPv6, firewall, ND/RA, neighbours, pools, routes, and settings.",
      "type": "object",
